---
// Static root redirect to the default locale. The node adapter swallows the
// `redirects` config at runtime, so for the static S3/CloudFront deploy we emit
// a real meta-refresh page that lands in dist/client/index.html.
const target = '/nb/';
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Oppskrifter</title>
    <script is:inline>window.location.replace('/nb/');</script>
  </head>
  <body>
    <a href={target}>Oppskrifter</a>
  </body>
</html>
