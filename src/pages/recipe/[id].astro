---
import Layout from '../../layouts/Layout.astro';
import recipesData from '../../../recipes.json';

export function getStaticPaths() {
  return recipesData.recipes.map(r => ({ params: { id: String(r.id) }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const ingredients = recipe.ingredients;
const steps = recipe.steps;
---

<Layout title={recipe.title}>
  <a href="/" class="ds-link inline-flex items-center gap-1 mb-6 no-underline">
    <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.53 4.47a.75.75 0 0 1 0 1.06L9.06 12l6.47 6.47a.75.75 0 1 1-1.06 1.06l-7-7a.75.75 0 0 1 0-1.06l7-7a.75.75 0 0 1 1.06 0Z"/></svg>
    Tilbake
  </a>

  <article class="flex flex-col gap-6 max-w-2xl">
    <div>
      <h2 class="ds-heading-lg">{recipe.title}</h2>
      <p class="ds-paragraph-sm text-(--ds-color-neutral-text-subtle) mt-2">{recipe.description}</p>
    </div>

    <div class="flex gap-4 text-sm text-(--ds-color-neutral-text-subtle)" id="macros"
      data-calories={recipe.calories}
      data-protein={recipe.protein_g}
      data-carbs={recipe.carbs_g}
      data-fat={recipe.fat_g}
    >
      <span class="flex items-center gap-1" title="Kalorier">
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M14.3199 2.32152C14.6478 2.47605 14.8182 2.84296 14.7248 3.19319L13.0869 9.33552L17.5697 9.75318C17.837 9.77808 18.0706 9.94395 18.1822 10.1881C18.2938 10.4322 18.2665 10.7174 18.1104 10.9359L10.6104 21.4359C10.3998 21.7308 10.0083 21.8329 9.68039 21.6784C9.35251 21.5238 9.18206 21.1569 9.27546 20.8067L10.9134 14.6644L6.43043 14.2467C6.16314 14.2218 5.92953 14.0559 5.81791 13.8118C5.70629 13.5676 5.73367 13.2825 5.88971 13.064L13.3898 2.56401C13.6005 2.26906 13.992 2.16699 14.3199 2.32152Z"/></svg>
        <span data-macro="calories">{recipe.calories}</span> kcal
      </span>
      <span class="flex items-center gap-1" title="Protein">
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M10 3.25C10.4142 3.25 10.75 3.58579 10.75 4V9C10.75 9.69036 11.3096 10.25 12 10.25C12.6904 10.25 13.25 9.69036 13.25 9V4C13.25 3.58579 13.5858 3.25 14 3.25C14.4142 3.25 14.75 3.58579 14.75 4V9C14.75 10.2588 13.9043 11.32 12.75 11.6465V20C12.75 20.4142 12.4142 20.75 12 20.75C11.5858 20.75 11.25 20.4142 11.25 20V11.6465C10.0957 11.32 9.25 10.2588 9.25 9V4C9.25 3.58579 9.58579 3.25 10 3.25ZM12.75 4C12.75 3.58579 12.4142 3.25 12 3.25C11.5858 3.25 11.25 3.58579 11.25 4V7.5C11.25 7.91421 11.5858 8.25 12 8.25C12.4142 8.25 12.75 7.91421 12.75 7.5V4Z"/></svg>
        <span data-macro="protein">{recipe.protein_g}</span>g protein
      </span>
      <span class="flex items-center gap-1" title="Karbohydrater">
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M4 7.25C3.58579 7.25 3.25 7.58579 3.25 8V11C3.25 13.939 5.12832 16.4393 7.75 17.3659V18C7.75 18.4142 8.08579 18.75 8.5 18.75H15.5C15.9142 18.75 16.25 18.4142 16.25 18V17.3659C18.8717 16.4393 20.75 13.939 20.75 11V8C20.75 7.58579 20.4142 7.25 20 7.25H4ZM10 16.25C7.10051 16.25 4.75 13.8995 4.75 11V8.75H19.25V11C19.25 13.8995 16.8995 16.25 14 16.25H10Z"/></svg>
        <span data-macro="carbs">{recipe.carbs_g}</span>g karbo
      </span>
      <span class="flex items-center gap-1" title="Fett">
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12.0022 2.25C12.4538 2.25 12.7244 2.56422 12.8425 2.76989L12.8521 2.78661L16.2094 9.39783L16.21 9.39892C16.2375 9.45279 16.2651 9.50672 16.2927 9.56072C17.2502 11.4321 18.25 13.3863 18.25 15.4365C18.25 18.9627 15.4658 21.75 11.9908 21.75C8.51248 21.75 5.75 18.9594 5.75 15.4365C5.75 13.387 6.73177 11.4327 7.67378 9.55757C7.69973 9.5059 7.72566 9.45429 7.75154 9.40273L7.75533 9.39519L11.1561 2.80617C11.2696 2.57771 11.5379 2.25 12.0022 2.25Z"/></svg>
        <span data-macro="fat">{recipe.fat_g}</span>g fett
      </span>
    </div>
    <div class="flex gap-4 text-sm text-(--ds-color-neutral-text-subtle)">
      <span class="flex items-center gap-1" title="Tilberedningstid">
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M3.75 12C3.75 7.44365 7.44365 3.75 12 3.75C16.5563 3.75 20.25 7.44365 20.25 12C20.25 16.5563 16.5563 20.25 12 20.25C7.44365 20.25 3.75 16.5563 3.75 12ZM12 2.25C6.61522 2.25 2.25 6.61522 2.25 12C2.25 17.3848 6.61522 21.75 12 21.75C17.3848 21.75 21.75 17.3848 21.75 12C21.75 6.61522 17.3848 2.25 12 2.25ZM12.75 6C12.75 5.58579 12.4142 5.25 12 5.25C11.5858 5.25 11.25 5.58579 11.25 6V12C11.25 12.1989 11.329 12.3897 11.4697 12.5303L13.9697 15.0303C14.2626 15.3232 14.7374 15.3232 15.0303 15.0303C15.3232 14.7374 15.3232 14.2626 15.0303 13.9697L12.75 11.6893V6Z"/></svg>
        ca. {recipe.cook_time_min} min
      </span>
    </div>

    <!-- Portions control -->
    <div class="flex items-center gap-3">
      <label class="ds-label" data-size="sm">Porsjoner:</label>
      <button class="ds-button ds-button--neutral" data-size="sm" id="portion-decrease">−</button>
      <output id="portion-display" class="ds-heading-xs w-8 text-center">1</output>
      <button class="ds-button ds-button--neutral" data-size="sm" id="portion-increase">+</button>
    </div>

    <!-- Ingredients -->
    <div>
      <h3 class="ds-heading-xs mb-3">Ingredienser</h3>
      <ul id="ingredients" class="flex flex-col gap-1">
        {ingredients.map(ing => (
          <li class="ds-paragraph-sm" data-base-amount={ing.amount} data-base-weight={ing.unit !== 'g' && ing.weight_g ? ing.weight_g : undefined}>
            <strong>{ing.amount} {ing.unit}</strong> {ing.name}
            {ing.unit !== 'g' && ing.weight_g ? <span class="text-(--ds-color-neutral-text-subtle)" data-weight>({ing.weight_g}g)</span> : null}
          </li>
        ))}
      </ul>
    </div>

    <!-- Steps -->
    <div>
      <h3 class="ds-heading-xs mb-3">Fremgangsmåte</h3>
      <ol class="flex flex-col gap-2 list-decimal list-inside">
        {steps.map(step => (
          <li class="ds-paragraph-sm">{step}</li>
        ))}
      </ol>
    </div>
  </article>
</Layout>

<script>
  const portionDisplay = document.getElementById('portion-display')!;
  const macrosEl = document.getElementById('macros')!;
  const ingredientItems = document.querySelectorAll('#ingredients li');
  const initialPortions = Number(new URLSearchParams(window.location.search).get('portions')) || 1;
  let portions = initialPortions;

  function formatAmount(amount: number): string {
    if (amount === Math.floor(amount)) return amount.toString();
    return parseFloat(amount.toFixed(2)).toString().replace('.', ',');
  }

  function update() {
    portionDisplay.textContent = String(portions);

    const url = new URL(window.location.href);
    if (portions > 1) {
      url.searchParams.set('portions', String(portions));
    } else {
      url.searchParams.delete('portions');
    }
    history.replaceState(null, '', url);

    // Update ingredients
    ingredientItems.forEach(li => {
      const el = li as HTMLElement;
      const base = Number(el.dataset.baseAmount);
      const scaled = formatAmount(base * portions);
      const strong = li.querySelector('strong');
      if (strong) {
        const parts = strong.textContent!.split(' ');
        parts[0] = scaled;
        strong.textContent = parts.join(' ');
      }
      const weightSpan = li.querySelector('[data-weight]');
      if (weightSpan && el.dataset.baseWeight) {
        const scaledWeight = Math.round(Number(el.dataset.baseWeight) * portions);
        weightSpan.textContent = `(${scaledWeight}g)`;
      }
    });
  }

  if (portions > 1) update();

  document.getElementById('portion-increase')!.addEventListener('click', () => {
    portions++;
    update();
  });

  document.getElementById('portion-decrease')!.addEventListener('click', () => {
    if (portions > 1) {
      portions--;
      update();
    }
  });
</script>
