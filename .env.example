# Database — Neon PostgreSQL connection string
# Local dev: use a Neon dev branch (create one at https://console.neon.tech)
# Production: use the Neon main branch (set via AWS SSM Parameter Store)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# better-auth session signing secret
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# better-auth base URL — must match the URL where the app is served
# Local dev: http://localhost:4321
# Production: your production domain (set via AWS SSM Parameter Store)
BETTER_AUTH_URL="http://localhost:4321"

# GitHub personal access token — used to trigger site rebuilds via workflow_dispatch
# Only needed in production; can be left empty for local dev
GITHUB_TOKEN=""
